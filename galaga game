import pgzrun
import random
WIDTH=750
HEIGHT=600
TITLE="Galaga Game"

#creating actors
ship=Actor("ship")
bug=Actor("bug")

ship.pos=(WIDTH//2,HEIGHT-60)
speed=10
bullets=[]
enemies=[]
enemies.append(bug)
enemies[-1].x=100
enemies[-1].y=-100
score=0
def displayScore():
    screen.draw.text(str(score),(100,30),fontsize=50)

def on_key_down(key):
    if key==keys.SPACE:

        bullets[-1].x=ship.x
        bullets[-1].y=ship.y-50

def update():
    global score
    if keyboard.left:
        ship.x-=5
        if ship. x<= 0:
            ship.x=0  
    # to make ship move right
    elif keyboard.right:
        ship.x += 5
        if ship.x >= WIDTH:
            ship.x=WIDTH
    # to fire bullet
    for bullet in bullets:
        if bullet.y <= 0:
            bullets.remove(bullet)
        else:
            bullet.y -= 10
    # to make enemy move down
    for enemy in enemies:
        enemy.y += 10
        if enemy.y >= HEIGHT:
            enemy.y=-100
            enemy.x=random.randint(30,WIDTH-30)
        # checking for collision
        for bullet in bullets:
            if enemy.colliderect(bullet):
                score +=20
                bullets.remove(bullet)
                enemies.remove(enemy)

def draw():
    screen.clear()
    screen.fill((20,40,255))
    for bullet in bullets:
        bullet.draw()
    for enemy in enemies:
        enemy.draw()
    ship.draw()
    displayScore()
pgzrun.go()
